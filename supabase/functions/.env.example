# Copy this file to supabase/functions/.env for local testing only.
# Never commit the real .env file.
ALLOWED_ORIGINS=https://YOUR_GITHUB_USERNAME.github.io,http://localhost:8080
TURNSTILE_EXPECTED_HOSTNAME=YOUR_GITHUB_USERNAME.github.io
TURNSTILE_SECRET_KEY=replace-with-cloudflare-secret-key
IP_HASH_SALT=replace-with-a-long-random-value
GOOGLE_CLIENT_ID=replace-with-google-oauth-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-oauth-client-secret
GOOGLE_REFRESH_TOKEN=replace-with-google-refresh-token
GOOGLE_DRIVE_FOLDER_ID=replace-with-google-drive-folder-id
